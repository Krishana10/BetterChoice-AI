# Copy to application-dev.yml and adjust for your local Postgres.
#
# Local Postgres (default in application-dev.yml): password 12345
# Docker Compose (docker/docker-compose.yml): password postgres
#   → set env: SPRING_DATASOURCE_PASSWORD=postgres

spring:
  datasource:
    url: ${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/betterchoice}
    username: ${SPRING_DATASOURCE_USERNAME:postgres}
    password: ${SPRING_DATASOURCE_PASSWORD:12345}
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.PostgreSQLDialect
  flyway:
    enabled: true
    locations: classpath:db/migration
    baseline-on-migrate: true

logging:
  level:
    com.betterchoice: DEBUG
    org.springframework.security: INFO
